---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="bg-surface-800 rounded-lg p-6 border border-surface-600 hover:border-brand-blue transition-colors">
  <a href={`/blog/${slug}/`} class="block">
    <time class="text-xs text-gray-500 uppercase tracking-widest">{formattedDate}</time>
    <h2 class="text-xl text-white mt-2 mb-2">{title}</h2>
    <p class="text-gray-400 text-sm mb-3">{description}</p>
    {tags.length > 0 && (
      <div class="flex gap-2">
        {tags.map((tag) => (
          <span class="text-xs px-2 py-1 rounded bg-surface-600 text-gray-400">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>
