---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Cuberact" description="Dev blog — gamedev, Godot, and tools.">
  <section class="max-w-3xl mx-auto px-4 py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl text-white mb-8">Blog</h1>

    {posts.length === 0 ? (
      <p class="text-gray-400">No posts yet. Check back soon.</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
