---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'cuberact-library',
    href: '/projects/cuberact-library/',
    description: 'A growing collection of GDExtension components for Godot 4.5+. Currently includes CRope2D — 2D rope physics with modular architecture.',
    tag: 'GDExtension',
    version: 'v1.0.0',
  },
];
---

<BaseLayout title="Projects — Cuberact" description="Tools, extensions, and games by Cuberact.">
  <section class="max-w-5xl mx-auto px-4 py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl text-white mb-4">Projects</h1>
    <p class="text-gray-400 mb-12">Tools, extensions, and games by Cuberact.</p>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.map(({ title, href, description, tag, version }) => (
        <a
          href={href}
          class="bg-surface-800 rounded-lg p-6 border border-surface-600 hover:border-brand-blue-light transition-colors block group"
        >
          <div class="flex items-start justify-between mb-3">
            <h2 class="text-white text-xl group-hover:text-brand-blue-light transition-colors">{title}</h2>
            <span class="px-2 py-0.5 text-xs rounded bg-brand-blue/20 text-brand-blue-light">{version}</span>
          </div>
          <span class="inline-block px-2 py-0.5 text-xs rounded bg-surface-600 text-gray-300 mb-3">{tag}</span>
          <p class="text-gray-400 text-sm">{description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
